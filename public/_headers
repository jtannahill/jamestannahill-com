# Cloudflare Workers Assets applies these to prerendered static pages.
# SSR routes also get headers from src/middleware.ts (defense-in-depth).

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin
  Permissions-Policy: accelerometer=(), autoplay=(self), camera=(), cross-origin-isolated=(), display-capture=(), encrypted-media=(self), fullscreen=(self), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(self), publickey-credentials-get=(), screen-wake-lock=(), sync-xhr=(), usb=(), web-share=(), xr-spatial-tracking=()
  X-Robots-Tag: index, follow
  Content-Security-Policy: default-src 'self'; script-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://challenges.cloudflare.com https://static.cloudflareinsights.com https://*.clarity.ms; style-src 'self' 'unsafe-inline' https://fonts.jamestannahill.com; font-src 'self' https://fonts.jamestannahill.com data:; img-src 'self' https: data: blob:; media-src 'self' https://media.jamestannahill.com; frame-src 'self' https://challenges.cloudflare.com; connect-src 'self' https://www.google-analytics.com https://*.googletagmanager.com https://stats.g.doubleclick.net https://challenges.cloudflare.com https://*.clarity.ms https://email.us-east-1.amazonaws.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests

# Resume PDF: shareable via direct link, but kept out of search indexes.
# More-specific path overrides the global "index, follow" above.
# inline => still opens in-browser; filename => recruiter's save dialog
# and downloads use a professional name instead of "resume.pdf".
/resume.pdf
  X-Robots-Tag: noindex, nofollow
  Content-Disposition: inline; filename="James_Tannahill_Resume.pdf"

/.well-known/*
  Cache-Control: public, max-age=86400

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/scripts/*
  Cache-Control: public, max-age=0, must-revalidate

/*.avif
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable
