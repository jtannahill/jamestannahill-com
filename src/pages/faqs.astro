---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const cdn = 'https://media.jamestannahill.com';
---
<BaseLayout
  title="James Tannahill | Contact & Professional Inquiries"
  description="Get in touch with James Tannahill - private equity advisory, value engineering, and strategic partnerships."
  canonical="https://jamestannahill.com/faqs/"
>
  <!-- Hero video: NYC night skyline -->
  <section class="relative flex flex-col justify-end pb-12 md:pb-16 px-6 md:px-14 overflow-hidden"
           style="background:#0a0a0a; min-height:62vh;">
    <video
      id="faq-hero-video"
      class="absolute inset-0 w-full h-full object-cover object-center"
      style="filter: brightness(0.75); z-index:0;"
      poster={`${cdn}/faq-hero-poster.jpg`}
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
      tabindex="-1"
    >
      <source src={`${cdn}/faq-hero-1080.mp4`} type="video/mp4" media="(min-width: 768px)" />
      <source src={`${cdn}/faq-hero-720.mp4`} type="video/mp4" />
    </video>
    <!-- Gradient overlay: heavy at bottom for text contrast -->
    <div class="absolute inset-0"
         style="background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.45) 55%, rgba(0,0,0,0.9) 100%); z-index:1;"></div>

    <div class="relative max-w-3xl" style="z-index:10;">
      <h1 class="font-bold leading-none text-white mb-5"
          style="font-family:'NHG Display',sans-serif; font-size:clamp(44px,7vw,80px); letter-spacing:-0.03em; animation: blurIn 1.1s ease both; animation-delay: 0.2s;">
        Get in Touch.
      </h1>
      <p class="text-[15px] leading-[1.75] max-w-lg text-white"
         style="opacity:0.55; animation: blurIn 0.9s ease both; animation-delay: 0.55s;">
        Advisory, partnerships, and professional inquiries. New York City and worldwide.
      </p>
    </div>
  </section>

  <script is:inline>
    (function () {
      var vid = document.getElementById('faq-hero-video');
      if (!vid) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        vid.removeAttribute('autoplay');
        vid.pause();
        return;
      }
      vid.play().catch(function () {});
    })();
  </script>

  <div class="relative" style="background:#0a0a0a;">
    <!-- Subtle gradient background -->
    <div class="absolute inset-0"
         style="background: radial-gradient(ellipse at 20% 50%, rgba(201,136,42,0.06) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(255,255,255,0.03) 0%, transparent 50%);"></div>

    <!-- Content -->
    <div class="relative max-w-4xl mx-auto px-6 py-16 md:py-24" style="z-index:1;">
      <ContactForm />
      <FAQAccordion />
    </div>
  </div>
</BaseLayout>
