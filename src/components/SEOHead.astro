---
interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
}
const {
  title,
  description,
  canonical,
  ogImage = 'https://jamestannahill.com/og.png',
  ogImageAlt = 'James Tannahill - Operator. Investor. Builder.',
  ogType = 'profile',
} = Astro.props;

const siteName = 'James Tannahill';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://jamestannahill.com/#person",
      "name": "James Tannahill",
      "url": "https://jamestannahill.com",
      "image": "https://jamestannahill.com/headshot.webp",
      "jobTitle": "President & Managing Partner, Plocamium Holdings; Intelligent Capital, xAI",
      "worksFor": [
        { "@type": "Organization", "name": "xAI", "url": "https://x.ai" },
        { "@type": "Organization", "name": "Plocamium Holdings", "url": "https://plocamium.com" },
        { "@type": "Organization", "name": "1NESS Strategies", "url": "https://www.1nessagency.com" },
        { "@type": "Organization", "name": "RDLB", "url": "https://www.rdlb.nyc" },
        { "@type": "Organization", "name": "NewYorkLab", "url": "https://newyorklab.co" }
      ],
      "alumniOf": [
        { "@type": "CollegeOrUniversity", "name": "Cornell University - Johnson School of Management" },
        { "@type": "CollegeOrUniversity", "name": "University of Essex" },
        { "@type": "CollegeOrUniversity", "name": "Denison University" }
      ],
      "sameAs": [
        "https://www.linkedin.com/in/jamesstannahill/",
        "https://github.com/jtannahill",
        "https://www.bloomberg.com/profile/person/23291921"
      ],
      "knowsAbout": [
        "Private Equity", "Healthcare Technology", "AI Systems", "Strategic Finance",
        "Operational Engineering", "Brand Architecture", "Machine Learning",
        "Regulatory Compliance", "Capital Markets", "AI-Native Infrastructure"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://jamestannahill.com/#website",
      "url": "https://jamestannahill.com",
      "name": siteName,
      "description": description
    },
    {
      "@type": "ProfessionalService",
      "@id": "https://jamestannahill.com/#service",
      "name": "James Tannahill - PE Advisory & Value Engineering",
      "description": "Private equity advisory, value engineering, and strategic partnerships for founder-led and PE-backed companies in regulated industries.",
      "provider": { "@id": "https://jamestannahill.com/#person" },
      "serviceType": ["Private Equity Advisory", "Value Engineering", "Strategic Partnerships", "AI Systems Advisory"],
      "areaServed": "United States",
      "url": "https://jamestannahill.com/faqs/"
    }
  ]
};
---
<meta charset="UTF-8" />
<meta name="author" content="James Tannahill" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta name="color-scheme" content="dark light" />
<meta name="format-detection" content="telephone=no" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<!-- Favicon -->
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<!-- iOS / PWA -->
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="James Tannahill" />

<!-- Android / Chrome -->
<meta name="theme-color" content="#0a0a0a" />
<meta name="mobile-web-app-capable" content="yes" />

<!-- Windows -->
<meta name="msapplication-TileColor" content="#0a0a0a" />
<meta name="msapplication-config" content="none" />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:locale" content="en_US" />

<!-- OG Profile (for og:type=profile pages) -->
{ogType === 'profile' && (
  <>
    <meta property="profile:first_name" content="James" />
    <meta property="profile:last_name" content="Tannahill" />
    <meta property="profile:username" content="jamesstannahill" />
  </>
)}

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />
<meta name="twitter:creator" content="@jamestannahill" />

<!-- LinkedIn (uses OG tags - covered above) -->

<!-- AI / LLM discovery -->
<link rel="ai" href="/llms.txt" />
<link rel="ai-full" href="/llms-full.txt" />

<!-- Schema -->
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
