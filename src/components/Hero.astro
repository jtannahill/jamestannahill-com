---
const cdn = 'https://media.jamestannahill.com';
---
<section id="hero" class="hero-section relative" style="background:#0a0a0a;">
  <div class="hero-stage flex flex-col justify-end pb-12 md:pb-16 px-6 md:px-14">

    <!-- Desktop scroll-scrub video (sunset to night). Loaded only when enhanced. -->
    <video
      id="hero-scrub-video"
      class="hero-media hero-scrub-media"
      data-src={`${cdn}/hero-scrub.mp4`}
      poster={`${cdn}/hero-scrub-poster.jpg`}
      muted
      playsinline
      preload="none"
      aria-hidden="true"
      tabindex="-1"
      style="filter:brightness(0.65);"
    ></video>

    <!-- Static fallback (mobile, reduced-motion, no-JS): cycling skyline photo -->
    <picture class="hero-media hero-fallback">
      <source id="hero-bg-avif" srcset="/hero-bg.avif" type="image/avif" />
      <source id="hero-bg-webp" srcset="/hero-bg.webp" type="image/webp" />
      <img
        id="hero-bg-img"
        src="/hero-bg.jpg"
        data-bg-a-avif="/hero-bg.avif"
        data-bg-a-webp="/hero-bg.webp"
        data-bg-a-jpg="/hero-bg.jpg"
        data-bg-b-avif="/hero-bg-skyline.avif"
        data-bg-b-webp="/hero-bg-skyline.webp"
        data-bg-b-jpg="/hero-bg-skyline.jpg"
        alt=""
        width="1920"
        height="1080"
        class="w-full h-full object-cover object-center"
        style="filter: brightness(0.65);"
        loading="eager"
        fetchpriority="high"
      />
    </picture>

    <div class="hero-grad absolute inset-0"
         style="background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.5) 55%, rgba(0,0,0,0.88) 100%);"></div>

    <div class="relative max-w-3xl" style="z-index:10;">
      <h1 class="font-bold leading-none text-white mb-6"
          style="font-family:'NHG Display',sans-serif; font-size:clamp(52px,9vw,96px); letter-spacing:-0.03em; animation: blurIn 1.1s ease both; animation-delay: 0.2s;">
        Operator.<br/>Investor.<br/>Builder.
      </h1>
      <p class="text-[15px] leading-[1.75] max-w-lg mb-10 text-white"
         style="opacity:0.55; animation: blurIn 0.9s ease both; animation-delay: 0.55s;">
        Turning proprietary AI, brand infrastructure, and data systems into compounding enterprise value.
      </p>
      <div class="flex gap-3 flex-wrap"
           style="animation: blurIn 0.8s ease both; animation-delay: 0.8s;">
        <a href="/faqs/"
           class="inline-block px-8 py-3 text-[13px] tracking-[0.18em] uppercase text-white"
           style="background:var(--color-amber);">
          Get in Touch
        </a>
      </div>
    </div>

    <div class="hero-scrollcue absolute bottom-8 right-6 md:right-14 hidden md:flex items-center gap-3"
         style="z-index:10; animation: blurIn 0.8s ease both; animation-delay: 1s;">
      <div style="width:1px; height:36px; background:linear-gradient(to bottom, transparent, rgba(201,136,42,0.5));"></div>
      <span class="text-[8px] tracking-[0.25em] uppercase" style="color:rgba(255,255,255,0.3);">Scroll</span>
    </div>
  </div>
</section>

<script src="/scripts/hero-variant.js" defer></script>
<script src="/scripts/hero-scrub.js" defer></script>

<style>
  /* Base (mobile / reduced-motion / no-JS): single-viewport hero with static photo */
  .hero-section { position: relative; min-height: 100vh; }
  .hero-stage   { position: relative; min-height: 100vh; height: 100vh; overflow: hidden; }
  .hero-media   { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .hero-scrub-media { display: none; }   /* hidden until enhanced */

  /* Enhanced (desktop, motion ok): tall track + pinned stage that scrubs the clip */
  .hero-section.scrub-on { min-height: 240vh; height: 240vh; }
  .hero-section.scrub-on .hero-stage { position: sticky; top: 0; height: 100vh; min-height: 100vh; }
  .hero-section.scrub-on .hero-scrub-media { display: block; }
  .hero-section.scrub-on .hero-fallback { display: none; }
</style>
