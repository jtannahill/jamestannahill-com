---
const cdn = 'https://d9ttkh3tz30f6.cloudfront.net/videos';
---
<style>
  .rdlb-video { max-height: 50vh; object-fit: contain; display: block; }
  @media (min-width: 768px) { .rdlb-video { max-height: 80vh; } }
</style>
<section style="background:#000; border-top: 1px solid rgba(201,136,42,0.2); border-bottom: 1px solid rgba(201,136,42,0.2);">
  <video
    poster={`${cdn}/rdlb-poster.jpg`}
    muted
    loop
    playsinline
    controls
    preload="metadata"
    class="rdlb-video w-full"
    x-webkit-airplay="allow"
  >
    <source src={`${cdn}/rdlb-brand-equity-capsule-1080.mp4`} type="video/mp4" media="(min-width: 768px)" />
    <source src={`${cdn}/rdlb-brand-equity-capsule-720.mp4`} type="video/mp4" />
  </video>
</section>

<script>
  // Attempt autoplay after user interaction on mobile
  const vid = document.querySelector('section video') as HTMLVideoElement;
  if (vid) {
    vid.play().catch(() => {
      // Autoplay blocked - user must tap controls, which is fine
    });
  }
</script>
