---
const videoUrl = 'https://d9ttkh3tz30f6.cloudfront.net/videos/RDLB-brand-reel.mp4';
---
<section style="background:#000; border-top: 1px solid rgba(201,136,42,0.2); border-bottom: 1px solid rgba(201,136,42,0.2);">
  <video
    src={videoUrl}
    poster="https://d9ttkh3tz30f6.cloudfront.net/videos/rdlb-poster.jpg"
    muted
    loop
    playsinline
    controls
    preload="metadata"
    class="w-full block"
    style="max-height: 80vh; object-fit: contain; display:block;"
    x-webkit-airplay="allow"
  />
</section>

<script>
  // Attempt autoplay after user interaction on mobile
  const vid = document.querySelector('section video') as HTMLVideoElement;
  if (vid) {
    vid.play().catch(() => {
      // Autoplay blocked — user must tap controls, which is fine
    });
  }
</script>
